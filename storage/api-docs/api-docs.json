            "post": {
                "tags": [
                    "Delay Notification"
                ],
                "summary": "Create a new delay notification",
                "operationId": "6d7ca186c880e43e494f3853aca9fd21",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "trip_id",
                                    "route_name",
                                    "delay_minutes",
                                    "delay_reason",
                                    "passenger_name",
                                    "passenger_email"
                                ],
                                "properties": {
                                    "trip_id": {
                                        "type": "string",
                                        "example": "TRIP001"
                                    },
                                    "route_name": {
                                        "type": "string",
                                        "example": "Jakarta - Bandung"
                                    },
                                    "departure_time": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-06-25T12:00:00Z",
                                        "nullable": true
                                    },
                                    "delay_minutes": {
                                        "type": "integer",
                                        "example": 30
                                    },
                                    "delay_reason": {
                                        "type": "string",
                                        "example": "Weather issue"
                                    },
                                    "passenger_name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "passenger_email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john.doe@example.com"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created successfully"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
