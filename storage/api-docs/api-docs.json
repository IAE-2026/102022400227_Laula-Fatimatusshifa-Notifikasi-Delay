            "get": {
                "tags": [
                    "Delay Notification"
                ],
                "summary": "Get trip delay status",
                "operationId": "ed1da54098d1f5fe309eb4d2d1eaaa6d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Trip ID",
